{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Selene",
  "mainBinaryName": "Selene",
  "version": "0.1.0",
  "identifier": "app.selene",
  "build": {
    "frontendDist": "../editor/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "B=$([ -d bundle ] && echo . || echo ..); npm --prefix $B/editor install && bash $B/bundle/fetch-deps.sh && npm --prefix $B/editor run dev",
    "beforeBuildCommand": "B=$([ -d bundle ] && echo . || echo ..); bash $B/bundle/fetch-deps.sh && npm --prefix $B/editor install && npm --prefix $B/editor run build"
  },
  "app": {
    "windows": [
      {
        "title": "Selene",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../vendor/ghc": "vendor/ghc",
      "../vendor/supercollider": "vendor/supercollider",
      "../vendor/quarks": "vendor/quarks",
      "../vendor/sc3-plugins": "vendor/sc3-plugins",
      "../vendor/sclang_conf.yaml": "vendor/sclang_conf.yaml",
      "../vendor/tidal-ghc-env": "vendor/tidal-ghc-env",
      "../backend": "backend",
      "../core": "core"
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
