{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Selene",
  "mainBinaryName": "Selene",
  "version": "0.1.0",
  "identifier": "app.selene",
  "build": {
    "frontendDist": "../editor/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm --prefix ../editor install && (bash ../bundle/fetch-deps.sh &) && npm --prefix ../editor run dev",
    "beforeBuildCommand": "bash ../bundle/fetch-deps.sh && npm --prefix ../editor install && npm --prefix ../editor run build"
  },
  "app": {
    "windows": [
      {
        "title": "Selene",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
